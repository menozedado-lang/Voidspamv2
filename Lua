-- MAIN BYPASS
-- ═══════════════════════════════════════════
local trackedParts = {}
local bypassHB     = nil
local bpChildAdd   = nil
local bpChildRem   = nil

local function stopBypass()
    if bypassHB   then bypassHB:Disconnect()   bypassHB=nil   end
    if bpChildAdd then bpChildAdd:Disconnect() bpChildAdd=nil end
    if bpChildRem then bpChildRem:Disconnect() bpChildRem=nil end
    trackedParts={} predCache={} nearestEnemyCache=nil nearestEnemyCacheTime=0
    cleanupPredSphere()
end

local function startBypass()
    stopBypass()
    bpChildAdd=workspace.ChildAdded:Connect(function(o)
        if not o:IsA("BasePart") then return end
        if o.Name=="CoreProjectile" then trackedParts[o]=true
        elseif o.Name=="Part" then
            task.defer(function()
                if o and o.Parent and o.AssemblyLinearVelocity.Magnitude>Config.SpeedThreshold then trackedParts[o]=true end
            end)
        end
    end)
    bpChildRem=workspace.ChildRemoved:Connect(function(o) trackedParts[o]=nil end)
    bypassHB=RunService.Heartbeat:Connect(function()
        frameCount=frameCount+1
        if Config.PredictionEnabled and frameCount%PRED_UPDATE_RATE==0 then
            for _,p in ipairs(playerCache) do
                local hrp=p.Character and p.Character:FindFirstChild("HumanoidRootPart")
                if hrp then updatePredCacheForPlayer(p,hrp) end
            end
        end
        local nearestOnly=Config.TargetMode=="Nearest Enemy" and getNearestEnemy() or nil
        if Config.PredictionEnabled and Config.PredictionShowSphere and frameCount%3==0 then
            local pt=nearestOnly or (Config.TargetMode=="Specific Player" and targetPlayerObj) or nearestEnemyCache
            if pt then updatePredSphere(getPredictedPosition(pt)) end
        elseif not Config.PredictionEnabled then cleanupPredSphere() end
        if Config.TeleportEnemies then
            local vx,vy,vz=Config.VoidPos.X,Config.VoidPos.Y,Config.VoidPos.Z
            for _,p in ipairs(playerCache) do
                if not shouldTargetPlayer(p) then continue end
                local skip=false
                if Config.TargetMode=="Nearest Enemy" then skip=p~=nearestOnly
                elseif Config.TargetMode=="Specific Player" then skip=p~=targetPlayerObj end
                if not skip and p.Character then
                    local h=p.Character:FindFirstChild("HumanoidRootPart")
                    if h then
                        if Config.PredictionEnabled then
                            local pred=getPredictedPosition(p)
                            h.CFrame=pred and CFrame.new(pred.X,vy,pred.Z) or CFrame.new(vx,vy,vz)
                        else h.CFrame=CFrame.new(vx,vy,vz) end
                        h.AssemblyLinearVelocity=Vector3.zero h.AssemblyAngularVelocity=Vector3.zero
                    end
                end
            end
        end
        if Config.TeleportProj or Config.TeleportFastParts then
            local vcf=CFrame.new(Config.VoidPos)
            for part in pairs(trackedParts) do
                if part and part.Parent then
                    local isProj=part.Name=="CoreProjectile"
                    if (isProj and Config.TeleportProj) or (not isProj and Config.TeleportFastParts) then
                        part.CFrame=vcf part.AssemblyLinearVelocity=Vector3.zero
                    end
                else trackedParts[part]=nil end
            end
        end
    end)
end

