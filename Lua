            Rayfield:Notify({ Title = "Specific Player", Content = "Enter username below", Duration = 4 })
        end
    end,
})

TargetsTab:CreateInput({
    Name = "Specific Player Username", PlaceholderText = "Enter exact username...",
    RemoveTextAfterFocusLost = false, Flag = "TargetUsername",
    Callback = function(v)
        Config.TargetPlayer = v
        targetPlayerObj     = nil
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name:lower() == v:lower() or p.DisplayName:lower() == v:lower() then
                targetPlayerObj = p
                Rayfield:Notify({ Title = "Target Found", Content = "Targeting: " .. p.Name, Duration = 3 })
                return
            end
        end
        if v ~= "" then
            Rayfield:Notify({ Title = "Not Found", Content = "'" .. v .. "' not in server", Duration = 3 })
        end
    end,
})

TargetsTab:CreateSection("Player List")

TargetsTab:CreateButton({
    Name = "Refresh Player List",
    Callback = function()
        local names = {}
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then table.insert(names, p.Name) end
        end
        Rayfield:Notify({
            Title   = "Players in Server",
            Content = #names > 0 and table.concat(names, ", ") or "No other players",
            Duration = 5,
        })
    end,
})

TargetsTab:CreateButton({
    Name = "Select Nearest Enemy",
    Callback = function()
        local nearest = getNearestEnemy()
        if nearest then
            Config.TargetMode   = "Specific Player"
            Config.TargetPlayer = nearest.Name
            targetPlayerObj     = nearest
            Rayfield:Notify({ Title = "Target Set", Content = "Targeting: " .. nearest.Name, Duration = 3 })
        else
            Rayfield:Notify({ Title = "No Enemies", Content = "No other players found", Duration = 3 })
        end
    end,
})

