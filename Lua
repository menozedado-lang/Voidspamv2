-- WEAPON SPEED
-- ═══════════════════════════════════════════
local DefaultReloadLengths = {
    Bow       = 0,
    Daggers   = 0.09,
    Slingshot = 0,
}

local WhitelistedItems = {"Bow", "Daggers", "Slingshot"}

local function applyWeaponSpeed(percent)
    local ok, err = pcall(function()
        local ItemLibrary = require(ReplicatedStorage.Modules.ItemLibrary)
        local Items       = rawget(ItemLibrary, "Items")
        if not Items then
            Rayfield:Notify({
                Title    = "Weapon Speed",
                Content  = "Could not find ItemLibrary.Items",
                Duration = 4,
            })
            return
        end

        local multiplier = (300 - percent) / 200

        for _, Item in Items do
            local Name = Item.Name
            if not table.find(WhitelistedItems, Name) then continue end
            if Item["ReloadLength"] == nil then continue end

            local base   = DefaultReloadLengths[Name] or 0
            local newVal = math.clamp(base * multiplier, 0, base * 3)

            if percent >= 300 then
                newVal = (Name == "Daggers") and 0.001 or 0
            end

            rawset(Item, "ReloadLength", newVal)
        end
    end)

    if not ok then
        Rayfield:Notify({
            Title    = "Weapon Speed Error",
            Content  = tostring(err),
            Duration = 5,
        })
    end
end

local function resetWeaponSpeed()
    pcall(function()
        local ItemLibrary = require(ReplicatedStorage.Modules.ItemLibrary)
        local Items       = rawget(ItemLibrary, "Items")
        if not Items then return end

        for _, Item in Items do
            local Name = Item.Name
            if not table.find(WhitelistedItems, Name) then continue end
            if Item["ReloadLength"] == nil then continue end
            rawset(Item, "ReloadLength", DefaultReloadLengths[Name] or 0)
        end
    end)
end

-- ═══════════════════════════════════════════
-- PROJECTILE PREDICTION
-- ═══════════════════════════════════════════

-- Stores last known velocity per player for prediction
local playerVelocityCache = {}

local function getPredictedPosition(player)
    local chr = player.Character
    if not chr then return nil end
    local hrp = chr:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local vel = hrp.AssemblyLinearVelocity

    -- Cache velocity for trend tracking
    if not playerVelocityCache[player] then
        playerVelocityCache[player] = { vel = vel, t = tick() }
    end

    local cache    = playerVelocityCache[player]
    local dt       = tick() - cache.t
    local accel    = dt > 0 and (vel - cache.vel) / dt or Vector3.zero

    -- Update cache
    playerVelocityCache[player] = { vel = vel, t = tick() }

    -- Lead time based on PredictionStrength
    local leadTime = Config.PredictionStrength

    -- Predicted position = current pos + vel*t + 0.5*accel*t^2
    local predicted = hrp.Position
        + vel    * leadTime
        + accel  * 0.5 * leadTime * leadTime

    -- Clamp lead distance so it doesn't overshoot wildly
    local maxLead = Config.PredictionMaxLead
    local delta   = predicted - hrp.Position
    if delta.Magnitude > maxLead then
        predicted = hrp.Position + delta.Unit * maxLead
    end

    return predicted
end

local function updatePredSphere(pos)
    if not Config.PredictionShowSphere then
        if predSphere then
            predSphere:Destroy()
            predSphere = nil
        end
        return
    end

    if not predSphere then
        predSphere             = Instance.new("Part")
        predSphere.Name        = "PredSphere"
        predSphere.Shape       = Enum.PartType.Ball
        predSphere.Size        = Vector3.new(2, 2, 2)
        predSphere.Anchored    = true
        predSphere.CanCollide  = false
        predSphere.Material    = Enum.Material.Neon
        predSphere.Color       = Color3.fromRGB(255, 50, 50)
        predSphere.Transparency = 0.4
        predSphere.Parent      = workspace
    end

    if pos then
        predSphere.CFrame = CFrame.new(pos)
    end
end

local function cleanupPredSphere()
    if predSphere then
        predSphere:Destroy()
        predSphere = nil
    end
end

-- ═══════════════════════════════════════════
-- CORE BYPASS FUNCTIONS
-- ═══════════════════════════════════════════
local function getVoidCFrame()
    return CFrame.new(Config.VoidPos)
end

local function shouldTargetPlayer(p)
    if p == LocalPlayer then return false end
    if Config.TargetMode == "All Enemies" then
        return true
    elseif Config.TargetMode == "Specific Player" then
        return targetPlayerObj ~= nil and p == targetPlayerObj
    elseif Config.TargetMode == "Nearest Enemy" then
        return true
    end
    return true
end

local function getNearestEnemy()
    local myChar = LocalPlayer.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end
    local nearest     = nil
    local nearestDist = math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local chr = p.Character
        local hrp = chr and chr:FindFirstChild("HumanoidRootPart")
        if hrp then
            local d = (hrp.Position - myHRP.Position).Magnitude
            if d < nearestDist then
                nearestDist = d
                nearest     = p
            end
        end
    end
    return nearest
end

-- ═══════════════════════════════════════════
-- START / STOP
-- ═══════════════════════════════════════════
local function stopBypass()
    if heartbeatConn    then heartbeatConn:Disconnect();    heartbeatConn    = nil end
    if childAddedConn   then childAddedConn:Disconnect();   childAddedConn   = nil end
    if childRemovedConn then childRemovedConn:Disconnect(); childRemovedConn = nil end
    trackedParts          = {}
    playerVelocityCache   = {}
    cleanupPredSphere()
end

local function startBypass()
    stopBypass()

    childAddedConn = workspace.ChildAdded:Connect(function(o)
        if not o:IsA("BasePart") then return end
        if o.Name == "CoreProjectile" then
            trackedParts[o] = true
        elseif o.Name == "Part" then
            task.defer(function()
                if o and o.Parent and
                   o.AssemblyLinearVelocity.Magnitude > Config.SpeedThreshold then
                    trackedParts[o] = true
                end
            end)
        end
    end)

    childRemovedConn = workspace.ChildRemoved:Connect(function(o)
        trackedParts[o] = nil
    end)

    heartbeatConn = RunService.Heartbeat:Connect(function()
        pcall(function()
            local voidCF      = getVoidCFrame()
            local nearestOnly = Config.TargetMode == "Nearest Enemy"
                                and getNearestEnemy() or nil

            -- ── Projectile Prediction ──
            -- Find the primary target for prediction display
            if Config.PredictionEnabled then
                local predTarget = nil

                if Config.TargetMode == "Nearest Enemy" then
                    predTarget = nearestOnly
                elseif Config.TargetMode == "Specific Player" then
                    predTarget = targetPlayerObj
                else
                    -- All Enemies → show nearest for the sphere
                    predTarget = getNearestEnemy()
                end

                if predTarget then
                    local pos = getPredictedPosition(predTarget)
                    updatePredSphere(pos)
                else
                    updatePredSphere(nil)
                end
            else
                cleanupPredSphere()
            end

            -- ── Teleport enemies ──
            if Config.TeleportEnemies then
                for _, p in ipairs(Players:GetPlayers()) do
                    if not shouldTargetPlayer(p) then continue end

                    local skip = false
                    if Config.TargetMode == "Nearest Enemy" then
                        skip = (p ~= nearestOnly)
                    elseif Config.TargetMode == "Specific Player" then
                        skip = (p ~= targetPlayerObj)
                    end

                    if not skip and p.Character then
                        local h = p.Character:FindFirstChild("HumanoidRootPart")
                        if h then
                            -- Use predicted position for teleport destination
                            -- so we "lead" where they are going
                            if Config.PredictionEnabled then
                                local predicted = getPredictedPosition(p)
                                if predicted then
                                    h.CFrame = CFrame.new(
                                        predicted.X,
                                        Config.VoidPos.Y,
                                        predicted.Z
                                    )
                                else
                                    h.CFrame = voidCF
                                end
                            else
                                h.CFrame = voidCF
                            end

                            h.AssemblyLinearVelocity  = Vector3.zero
                            h.AssemblyAngularVelocity = Vector3.zero
                        end
                    end
                end
            end

            -- ── Teleport tracked parts ──
            if Config.TeleportProj or Config.TeleportFastParts then
                for part, _ in pairs(trackedParts) do
                    if part and part.Parent then
                        local isProj = part.Name == "CoreProjectile"
                        local isFast = not isProj

                        if (isProj and Config.TeleportProj) or
                           (isFast and Config.TeleportFastParts) then
                            part.CFrame                 = voidCF
                            part.AssemblyLinearVelocity = Vector3.zero
                        end
                    else
                        trackedParts[part] = nil
                    end
                end
            end
        end)
    end)
end

