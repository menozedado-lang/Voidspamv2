-- ═══════════════════════════════════════════
-- IMPROVED PREDICTION STATE
-- ═══════════════════════════════════════════

-- Per-player prediction data
local predCache = {}
-- {
--   pos      = Vector3   last known position
--   vel      = Vector3   last known velocity
--   accel    = Vector3   estimated acceleration
--   smoothed = Vector3   EMA smoothed predicted point
--   t        = number    last update time
--   history  = {}        ring buffer of {pos, t} for velocity estimation
-- }

local HISTORY_SIZE   = 6   -- frames to keep for velocity estimation
local GRAVITY        = Vector3.new(0, -workspace.Gravity, 0)

local function initPredCache(player)
    predCache[player] = {
        pos      = Vector3.zero,
        vel      = Vector3.zero,
        accel    = Vector3.zero,
        smoothed = Vector3.zero,
        t        = tick(),
        history  = {},
    }
end

-- Weighted least-squares velocity from position history
local function estimateVelocityFromHistory(history)
    if #history < 2 then return Vector3.zero end
    -- Simple finite difference over last two samples
    local newest = history[#history]
    local oldest = history[1]
    local dt     = newest.t - oldest.t
    if dt <= 0 then return Vector3.zero end
    return (newest.pos - oldest.pos) / dt
end

-- Estimate acceleration from velocity history
local function estimateAccelFromHistory(history)
    if #history < 3 then return Vector3.zero end
    local n   = #history
    local h1  = history[n]
    local h2  = history[n - 1]
    local h3  = history[n - 2]
    local dt1 = h1.t - h2.t
    local dt2 = h2.t - h3.t
    if dt1 <= 0 or dt2 <= 0 then return Vector3.zero end
    local v1 = (h1.pos - h2.pos) / dt1
    local v2 = (h2.pos - h3.pos) / dt2
    return (v1 - v2) / ((dt1 + dt2) * 0.5)
end

local function updatePredCache(player, hrp)
    local now = tick()
    local pos = hrp.Position

    if not predCache[player] then initPredCache(player) end
    local cache = predCache[player]

    -- Push to history ring buffer
    table.insert(cache.history, { pos = pos, t = now })
    if #cache.history > HISTORY_SIZE then
        table.remove(cache.history, 1)
    end

    local dt = now - cache.t
    cache.t  = now

    -- Estimate vel / accel from history for smoother results
    local newVel   = estimateVelocityFromHistory(cache.history)
    local newAccel = estimateAccelFromHistory(cache.history)

    -- Blend with assembly velocity for responsiveness
    local assemblyVel = hrp.AssemblyLinearVelocity
    -- Weight: 70% history-estimated, 30% assembly (assembly can spike)
    newVel = newVel * 0.7 + assemblyVel * 0.3

    cache.vel   = newVel
    cache.accel = newAccel
    cache.pos   = pos
end

--[[
    Main prediction function.
    Returns a world-space Vector3 of where the target will be
    at (now + leadTime + latency).
]]
local function getPredictedPosition(player)
    local chr = player.Character
    if not chr then return nil end
    local hrp = chr:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    updatePredCache(player, hrp)
    local cache = predCache[player]

    -- Total lead time = user setting + latency compensation
    local totalLead = Config.PredictionStrength + Config.PredictionLatency

    -- Adaptive scaling: faster targets need less lead (they reach point sooner)
    -- slower targets need more
    if Config.PredictionAdaptive then
        local speed = cache.vel.Magnitude
        -- Scale: at 0 studs/s use full lead, at 50 studs/s scale to 0.6x
        local scale = math.clamp(1 - (speed / 200), 0.4, 1.4)
        totalLead   = totalLead * scale
    end

    local predicted

    if Config.PredictionMethod == "Velocity Only" then
        -- Simple: pos + vel * t
        predicted = cache.pos + cache.vel * totalLead

    elseif Config.PredictionMethod == "Velocity + Accel" then
        -- Kinematic: pos + vel*t + 0.5*accel*t²
        predicted = cache.pos
            + cache.vel  * totalLead
            + cache.accel * 0.5 * totalLead * totalLead

    elseif Config.PredictionMethod == "Kalman" then
        -- Simplified Kalman-like: blend kinematic prediction
        -- with a dampened accel to reduce overshoot
        local dampedAccel = cache.accel * 0.5
        predicted = cache.pos
            + cache.vel  * totalLead
            + dampedAccel * 0.5 * totalLead * totalLead
    else
        predicted = cache.pos + cache.vel * totalLead
    end

    -- Clamp max lead distance
    local delta = predicted - cache.pos
    if delta.Magnitude > Config.PredictionMaxLead then
        predicted = cache.pos + delta.Unit * Config.PredictionMaxLead
    end

    -- EMA smoothing to reduce jitter
    local sf = Config.PredictionSmoothFactor
    if sf > 0 then
        if cache.smoothed == Vector3.zero then
            cache.smoothed = predicted
        else
            cache.smoothed = cache.smoothed * sf + predicted * (1 - sf)
        end
        predicted = cache.smoothed
    end

    return predicted
end

-- ═══════════════════════════════════════════
-- PREDICTION SPHERE
-- ═══════════════════════════════════════════
local function updatePredSphere(pos)
    if not Config.PredictionShowSphere then
        if predSphere then predSphere:Destroy() predSphere = nil end
        return
    end
    if not predSphere then
        predSphere              = Instance.new("Part")
        predSphere.Name         = "PredSphere"
        predSphere.Shape        = Enum.PartType.Ball
        predSphere.Size         = Vector3.new(2, 2, 2)
        predSphere.Anchored     = true
        predSphere.CanCollide   = false
        predSphere.Material     = Enum.Material.Neon
        predSphere.Color        = Color3.fromRGB(255, 50, 50)
        predSphere.Transparency = 0.35
        predSphere.Parent       = workspace
    end
    if pos then predSphere.CFrame = CFrame.new(pos) end
end

local function cleanupPredSphere()
    if predSphere then predSphere:Destroy() predSphere = nil end
end

