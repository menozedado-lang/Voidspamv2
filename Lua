-- WEAPONS BYPASS
-- ═══════════════════════════════════════════
local WeaponDefaults = { Slingshot={ReloadLength=0}, Bow={ReloadLength=0}, Daggers={ReloadLength=0.09}, Gunblade={ReloadLength=0} }

local function getItems()
    local ok,IL=pcall(function() return require(ReplicatedStorage.Modules.ItemLibrary) end)
    if not ok then return nil end
    return rawget(IL,"Items")
end

local function applyWeaponBypass(name,enabled,speed)
    local Items=getItems() if not Items then return end
    for _,Item in Items do
        if Item.Name==name then
            if Item["ReloadLength"]==nil then continue end
            if enabled then
                local base=WeaponDefaults[name] and WeaponDefaults[name].ReloadLength or 0
                local mult=(300-speed)/200
                local nv=math.clamp(base*mult,0,base*3)
                if speed>=300 then nv=(name=="Daggers") and 0.001 or 0 end
                rawset(Item,"ReloadLength",nv)
            else
                rawset(Item,"ReloadLength",WeaponDefaults[name] and WeaponDefaults[name].ReloadLength or 0)
            end
        end
    end
end

local function applyAllWeapons()
    if Config.SlingshotEnabled then applyWeaponBypass("Slingshot",true,Config.SlingshotSpeed) end
    if Config.BowEnabled       then applyWeaponBypass("Bow",true,Config.WeaponSpeed)          end
    if Config.DaggersEnabled   then applyWeaponBypass("Daggers",true,Config.WeaponSpeed)      end
    if Config.GunbladeEnabled  then applyWeaponBypass("Gunblade",true,Config.WeaponSpeed)     end
end

local function resetAllWeapons()
    for name in pairs(WeaponDefaults) do applyWeaponBypass(name,false,100) end
end

