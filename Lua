-- PREDICTION
-- ═══════════════════════════════════════════
local predCache    = {}
local HISTORY_SIZE = 5
local predSphere   = nil

local function initPredCache(p)
    predCache[p]={pos=Vector3.zero,vel=Vector3.zero,accel=Vector3.zero,smoothed=nil,history={}}
end

local function updatePredCacheForPlayer(p,hrp)
    local now=tick() local pos=hrp.Position
    if not predCache[p] then initPredCache(p) end
    local c=predCache[p] local h=c.history
    h[#h+1]={pos=pos,t=now}
    if #h>HISTORY_SIZE then table.remove(h,1) end
    if #h>=2 then
        local dt=h[#h].t-h[1].t
        if dt>0 then c.vel=(h[#h].pos-h[1].pos)/dt*0.65+hrp.AssemblyLinearVelocity*0.35 end
    else c.vel=hrp.AssemblyLinearVelocity end
    if #h>=3 then
        local n=#h local dt1=h[n].t-h[n-1].t local dt2=h[n-1].t-h[n-2].t
        if dt1>0 and dt2>0 then
            c.accel=((h[n].pos-h[n-1].pos)/dt1-(h[n-1].pos-h[n-2].pos)/dt2)/((dt1+dt2)*0.5)
        end
    end
    c.pos=pos
end

local function getPredictedPosition(p)
    local c=predCache[p] if not c then return nil end
    local tl=Config.PredictionStrength+Config.PredictionLatency
    if Config.PredictionAdaptive then
        local sc=math.clamp(1-c.vel.Magnitude/200,0.4,1.4) tl=tl*sc
    end
    local pred
    if Config.PredictionMethod=="Velocity Only" then pred=c.pos+c.vel*tl
    elseif Config.PredictionMethod=="Velocity + Accel" then pred=c.pos+c.vel*tl+c.accel*(0.5*tl*tl)
    else pred=c.pos+c.vel*tl+c.accel*0.5*(0.5*tl*tl) end
    local delta=pred-c.pos local mag=delta.Magnitude
    if mag>Config.PredictionMaxLead then pred=c.pos+delta*(Config.PredictionMaxLead/mag) end
    local sf=Config.PredictionSmoothFactor
    if sf>0 then
        c.smoothed=c.smoothed and c.smoothed*sf+pred*(1-sf) or pred
        pred=c.smoothed
    end
    return pred
end

local function updatePredSphere(pos)
    if not Config.PredictionShowSphere then
        if predSphere then predSphere:Destroy() predSphere=nil end return
    end
    if not predSphere then
        predSphere=Instance.new("Part") predSphere.Name="PredSphere"
        predSphere.Shape=Enum.PartType.Ball predSphere.Size=Vector3.new(2,2,2)
        predSphere.Anchored=true predSphere.CanCollide=false
        predSphere.Material=Enum.Material.Neon predSphere.Color=Color3.fromRGB(255,50,50)
        predSphere.Transparency=0.35 predSphere.Parent=workspace
    end
    if pos then predSphere.CFrame=CFrame.new(pos) end
end

local function cleanupPredSphere()
    if predSphere then predSphere:Destroy() predSphere=nil end
end

