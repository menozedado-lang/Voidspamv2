local ConfigFolder = "unnamed"
local ConfigFile   = ConfigFolder .. "/rivals_config.json"

local SaveableKeys = {
    "Enabled", "TeleportEnemies", "TeleportProj", "TeleportFastParts",
    "SpeedThreshold", "TargetMode", "TargetPlayer",
    "WeaponSpeedEnabled", "WeaponSpeedPercent",
    "PredictionEnabled", "PredictionMethod", "PredictionStrength",
    "PredictionMaxLead", "PredictionShowSphere", "PredictionLatency",
    "PredictionGravityComp", "PredictionSmoothFactor", "PredictionAdaptive",
    "VoidPosX", "VoidPosY", "VoidPosZ",
    "AvatarVictimId", "AvatarHelper", "AvatarLevel", "AvatarStreak",
    "AvatarElo", "AvatarKeys", "AvatarPremium", "AvatarVerified",
    "AvatarUnlockAll", "AvatarPlatform",
}

local function saveConfig()
    local ok, err = pcall(function()
        if not isfolder(ConfigFolder) then makefolder(ConfigFolder) end
        local data = {}
        for _, key in ipairs(SaveableKeys) do
            if key == "VoidPosX" then data[key] = Config.VoidPos.X
            elseif key == "VoidPosY" then data[key] = Config.VoidPos.Y
            elseif key == "VoidPosZ" then data[key] = Config.VoidPos.Z
            else data[key] = Config[key] end
        end
        writefile(ConfigFile, HttpService:JSONEncode(data))
    end)
    if not ok then
        Rayfield:Notify({ Title = "Save Failed", Content = tostring(err), Duration = 4 })
    end
end

local function loadConfig()
    local ok, err = pcall(function()
        if not isfolder(ConfigFolder) then makefolder(ConfigFolder) end
        if not isfile(ConfigFile) then return end
        local data = HttpService:JSONDecode(readfile(ConfigFile))
        for _, key in ipairs(SaveableKeys) do
            if key == "VoidPosX" and data[key] then
                Config.VoidPos = Vector3.new(data[key], Config.VoidPos.Y, Config.VoidPos.Z)
            elseif key == "VoidPosY" and data[key] then
                Config.VoidPos = Vector3.new(Config.VoidPos.X, data[key], Config.VoidPos.Z)
            elseif key == "VoidPosZ" and data[key] then
                Config.VoidPos = Vector3.new(Config.VoidPos.X, Config.VoidPos.Y, data[key])
            else
                if data[key] ~= nil then Config[key] = data[key] end
            end
        end
    end)
    if not ok then
        Rayfield:Notify({ Title = "Load Failed", Content = tostring(err), Duration = 4 })
    end
end

loadConfig()

