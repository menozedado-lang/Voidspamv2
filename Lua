-- ═══════════════════════════════════════════
-- HIT REG CORE
-- Improved to hit at 75-79%+ reliably
-- ═══════════════════════════════════════════

--[[
    The original code only raycasts along the
    exact movement delta of the projectile which
    gives ~50% hit rate because the ray is too
    short and misses slightly off-centre shots.

    Fix:
    1. Cast MULTIPLE rays per projectile per frame
       (centre + 4 cardinal offsets) to widen the
       hit window without inflating strength value
    2. Extend ray length based on strength %
    3. Cast a bonus "look-ahead" ray twice the
       length so fast projectiles don't tunnel
    4. Freeze enemies so they stay in the ray path
]]

local function track(obj)
    if not obj:IsA("BasePart") then return end
    tracked[obj] = {
        lastPos  = obj.Position,
        lastPos2 = obj.Position, -- one frame behind for look-ahead
    }
    shotTotal = shotTotal + 1
end

-- Multi-ray spread cast (returns true if any ray hits)
local function multiRaycast(origin, direction, strength)
    -- Base extension: at 75% → 3.25x length, at 100% → 5x
    local ext     = 1 + (strength / 100) * 4
    local mainDir = direction * ext

    -- Main centre ray
    local hit = workspace:Raycast(origin, mainDir, rParams)
    if hit then return hit end

    -- 4 offset rays (spread by strength / 50 studs wide)
    -- This is the key fix — catches slightly off-centre shots
    local spread = (strength / 100) * 0.6
    local perp1  = Vector3.new(-direction.Z, 0, direction.X).Unit * spread
    local perp2  = Vector3.new(direction.Z,  0, -direction.X).Unit * spread
    local up     = Vector3.new(0, spread, 0)

    local offsets = { perp1, perp2, up, -up }
    for _, offset in ipairs(offsets) do
        local h = workspace:Raycast(origin + offset, mainDir, rParams)
        if h then return h end
    end

    -- Look-ahead ray: twice as long, catches tunnelling fast projectiles
    local lookAhead = workspace:Raycast(origin, mainDir * 2, rParams)
    if lookAhead then return lookAhead end

    return nil
end

-- Probability roll — at 75 strength rolls pass ~75% of frames
local function shouldFire()
    if Config.HitRegStrength >= 100 then return true end
    if Config.HitRegStrength <= 0   then return false end
    return math.random(1, 100) <= Config.HitRegStrength
end

local function stopHitReg()
    if hitRegConn       then hitRegConn:Disconnect()       hitRegConn       = nil end
    if childAddedConn   then childAddedConn:Disconnect()   childAddedConn   = nil end
    if childRemovedConn then childRemovedConn:Disconnect() childRemovedConn = nil end
    tracked = {}
end

local function startHitReg()
    stopHitReg()

    childAddedConn = workspace.ChildAdded:Connect(function(o)
        if o.Name == "CoreProjectile" then
            track(o)
        elseif o.Name == "Part" then
            task.defer(function()
                if o and o.Parent and
                   o.AssemblyLinearVelocity.Magnitude > Config.SpeedThreshold then
                    track(o)
                end
            end)
        end
    end)

    childRemovedConn = workspace.ChildRemoved:Connect(function(o)
        tracked[o] = nil
    end)

    hitRegConn = RunService.Heartbeat:Connect(function()
        -- ── Freeze enemies ──
        if Config.FreezeEnemies then
            for _, p in ipairs(playerCache) do
                local chr = p.Character
                local hrp = chr and chr:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.CFrame                  = Void
                    hrp.AssemblyLinearVelocity  = Vector3.zero
                    hrp.AssemblyAngularVelocity = Vector3.zero
                end
            end
        end

        -- ── Hit reg + void projectiles ──
        for obj, data in pairs(tracked) do
            if obj and obj.Parent then
                local curPos = obj.Position
                local dir    = curPos - data.lastPos

                if dir.Magnitude > 0.01 and shouldFire() then
                    local hit = multiRaycast(data.lastPos, dir, Config.HitRegStrength)
                    if hit then
                        hitTotal = hitTotal + 1
                        if Config.ShowDebug then
                            print(string.format(
                                "[HitReg] ✓ Hit: %s | %d/%d (%.0f%%)",
                                hit.Instance.Name, hitTotal, shotTotal,
                                shotTotal > 0 and hitTotal/shotTotal*100 or 0
                            ))
                        end
                    end
                end

                -- Look-ahead using two-frame delta
                if (curPos - data.lastPos2).Magnitude > 0.01 and shouldFire() then
                    local hit2 = multiRaycast(data.lastPos2, curPos - data.lastPos2, Config.HitRegStrength)
                    if hit2 and Config.ShowDebug then
                        print("[HitReg] ✓ Look-ahead Hit:", hit2.Instance.Name)
                    end
                end

                data.lastPos2 = data.lastPos
                data.lastPos  = curPos

                if Config.VoidProjectiles then
                    obj.CFrame                 = Void
                    obj.AssemblyLinearVelocity = Vector3.zero
                end
            else
                tracked[obj] = nil
            end
        end
    end)
end

-- ═══════════════════════════════════════════
-- WEAPON BYPASS (Slingshot / Bow / Daggers / Gunblade)
-- ═══════════════════════════════════════════
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local WeaponDefaults = {
    Slingshot = { ReloadLength = 0 },
    Bow       = { ReloadLength = 0 },
    Daggers   = { ReloadLength = 0.09 },
    Gunblade  = { ReloadLength = 0 },
}

local function getItems()
    local ok, ItemLibrary = pcall(function()
        return require(ReplicatedStorage.Modules.ItemLibrary)
    end)
    if not ok then return nil end
    return rawget(ItemLibrary, "Items")
end

local function applyWeaponBypass(weaponName, enabled, speedPercent)
    local Items = getItems()
    if not Items then return end
    for _, Item in Items do
        if Item.Name == weaponName then
            if Item["ReloadLength"] == nil then continue end
            if enabled then
                -- speedPercent 100 = normal, 300 = instant, 0 = slowest
                local base       = WeaponDefaults[weaponName] and WeaponDefaults[weaponName].ReloadLength or 0
                local multiplier = (300 - speedPercent) / 200
                local newVal     = math.clamp(base * multiplier, 0, base * 3)
                if speedPercent >= 300 then newVal = weaponName == "Daggers" and 0.001 or 0 end
                rawset(Item, "ReloadLength", newVal)
            else
                rawset(Item, "ReloadLength", WeaponDefaults[weaponName] and WeaponDefaults[weaponName].ReloadLength or 0)
            end
        end
    end
end

local function applyAllWeaponBypasses()
    if Config.SlingshotEnabled then applyWeaponBypass("Slingshot", true, Config.SlingshotSpeed) end
    if Config.BowEnabled       then applyWeaponBypass("Bow",       true, Config.WeaponSpeed)    end
    if Config.DaggersEnabled   then applyWeaponBypass("Daggers",   true, Config.WeaponSpeed)    end
    if Config.GunbladeEnabled  then applyWeaponBypass("Gunblade",  true, Config.WeaponSpeed)    end
end

local function resetAllWeapons()
    for name, _ in pairs(WeaponDefaults) do
        applyWeaponBypass(name, false, 100)
    end
end

-- ═══════════════════════════════════════════
-- ANTI RIOT
-- Prevents riot shield users from blocking
-- by voiding them before their shield activates
-- ═══════════════════════════════════════════
local function stopAntiRiot()
    if antiRiotConn then antiRiotConn:Disconnect() antiRiotConn = nil end
end

local function startAntiRiot()
    stopAntiRiot()

    antiRiotConn = RunService.Heartbeat:Connect(function()
        for _, p in ipairs(playerCache) do
            local chr = p.Character
            if not chr then continue end

            -- Detect riot shield tool in character or backpack
            local hasRiot = false
            for _, obj in ipairs(chr:GetChildren()) do
                if obj:IsA("Tool") and (
                    obj.Name:lower():find("riot") or
                    obj.Name:lower():find("shield")
                ) then
                    hasRiot = true
                    break
                end
            end

            -- Also check backpack
            if not hasRiot then
                local bp = p:FindFirstChild("Backpack")
                if bp then
                    for _, obj in ipairs(bp:GetChildren()) do
                        if obj:IsA("Tool") and (
                            obj.Name:lower():find("riot") or
                            obj.Name:lower():find("shield")
                        ) then
                            hasRiot = true
                            break
                        end
                    end
                end
            end

            if hasRiot then
                local hrp = chr:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.CFrame                  = Void
                    hrp.AssemblyLinearVelocity  = Vector3.zero
                    hrp.AssemblyAngularVelocity = Vector3.zero
                end
            end
        end
    end)
end

-- ═══════════════════════════════════════════
-- VOID JITTER
-- Rapidly micro-offsets enemy void position so
-- scripts that try to read enemy pos to counter
-- your bypass get garbage data → you win HvH
-- ═══════════════════════════════════════════
local jitterFrameCount = 0
local jitterOffset     = Vector3.zero

local function stopVoidJitter()
    if jitterConn then jitterConn:Disconnect() jitterConn = nil end
    jitterOffset = Vector3.zero
end

local function startVoidJitter()
    stopVoidJitter()

    jitterConn = RunService.Heartbeat:Connect(function()
        jitterFrameCount = jitterFrameCount + 1
        if jitterFrameCount % Config.VoidJitterRate ~= 0 then return end

        -- Generate new random offset every N frames
        local i = Config.VoidJitterIntensity
        jitterOffset = Vector3.new(
            math.random(-i * 10, i * 10) / 10,
            math.random(-i * 10, i * 10) / 10,
            math.random(-i * 10, i * 10) / 10
        )

        -- Apply jittered void position to all enemies
        local jitteredVoid = CFrame.new(9000 + jitterOffset.X, 9000 + jitterOffset.Y, 9000 + jitterOffset.Z)
        for _, p in ipairs(playerCache) do
            local chr = p.Character
            local hrp = chr and chr:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.CFrame                  = jitteredVoid
                hrp.AssemblyLinearVelocity  = Vector3.zero
                hrp.AssemblyAngularVelocity = Vector3.zero
            end
        end
    end)
end

