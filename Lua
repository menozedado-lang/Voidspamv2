-- WEAPON SPEED
-- ═══════════════════════════════════════════
local DefaultReloadLengths = { Bow = 0, Daggers = 0.09, Slingshot = 0 }
local WhitelistedItems     = {"Bow", "Daggers", "Slingshot"}

local function applyWeaponSpeed(percent)
    pcall(function()
        local ItemLibrary = require(ReplicatedStorage.Modules.ItemLibrary)
        local Items       = rawget(ItemLibrary, "Items")
        if not Items then return end
        local multiplier  = (300 - percent) / 200
        for _, Item in Items do
            local Name = Item.Name
            if not table.find(WhitelistedItems, Name) then continue end
            if Item["ReloadLength"] == nil then continue end
            local base   = DefaultReloadLengths[Name] or 0
            local newVal = math.clamp(base * multiplier, 0, base * 3)
            if percent >= 300 then newVal = (Name == "Daggers") and 0.001 or 0 end
            rawset(Item, "ReloadLength", newVal)
        end
    end)
end

local function resetWeaponSpeed()
    pcall(function()
        local ItemLibrary = require(ReplicatedStorage.Modules.ItemLibrary)
        local Items       = rawget(ItemLibrary, "Items")
        if not Items then return end
        for _, Item in Items do
            local Name = Item.Name
            if not table.find(WhitelistedItems, Name) then continue end
            if Item["ReloadLength"] == nil then continue end
            rawset(Item, "ReloadLength", DefaultReloadLengths[Name] or 0)
        end
    end)
end

