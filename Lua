-- ANTI RIOT
-- ═══════════════════════════════════════════
local antiRiotConn=nil
local function stopAntiRiot()
    if antiRiotConn then antiRiotConn:Disconnect() antiRiotConn=nil end
end
local function startAntiRiot()
    stopAntiRiot()
    antiRiotConn=RunService.Heartbeat:Connect(function()
        for _,p in ipairs(playerCache) do
            local chr=p.Character if not chr then continue end
            local hasRiot=false
            for _,obj in ipairs(chr:GetChildren()) do
                if obj:IsA("Tool") and (obj.Name:lower():find("riot") or obj.Name:lower():find("shield")) then
                    hasRiot=true break end
            end
            if not hasRiot then
                local bp=p:FindFirstChild("Backpack")
                if bp then
                    for _,obj in ipairs(bp:GetChildren()) do
                        if obj:IsA("Tool") and (obj.Name:lower():find("riot") or obj.Name:lower():find("shield")) then
                            hasRiot=true break end
                    end
                end
            end
            if hasRiot then
                local hrp=chr:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.CFrame=Void hrp.AssemblyLinearVelocity=Vector3.zero hrp.AssemblyAngularVelocity=Vector3.zero
                end
            end
        end
    end)
end

