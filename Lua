-- TARGETS TAB
-- ═══════════════════════════════════════════
local TargetsTab = Window:CreateTab("Targets", "crosshair")

TargetsTab:CreateSection("Target Selection")

TargetsTab:CreateDropdown({
    Name         = "Target Mode",
    Options      = {"All Enemies", "Nearest Enemy", "Specific Player"},
    CurrentOption = "All Enemies",
    Flag         = "TargetMode",
    Callback     = function(v)
        Config.TargetMode = v
        if v == "Specific Player" then
            Rayfield:Notify({
                Title   = "Specific Player",
                Content = "Enter a username in the box below",
                Duration = 4,
            })
        end
    end,
})

TargetsTab:CreateInput({
    Name        = "Specific Player Username",
    PlaceholderText = "Enter exact username...",
    RemoveTextAfterFocusLost = false,
    Flag        = "TargetUsername",
    Callback    = function(v)
        Config.TargetPlayer = v
        targetPlayerObj = nil
        -- Search for the player
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name:lower() == v:lower() or p.DisplayName:lower() == v:lower() then
                targetPlayerObj = p
                Rayfield:Notify({
                    Title   = "Target Found",
                    Content = "Targeting: " .. p.Name,
                    Duration = 3,
                })
                return
            end
        end
        if v ~= "" then
            Rayfield:Notify({
                Title   = "Not Found",
                Content = "Player '"..v.."' not in server",
                Duration = 3,
            })
        end
    end,
})

TargetsTab:CreateSection("Player List")

local function buildPlayerList()
    local names = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            table.insert(names, p.Name)
        end
    end
    return names
end

-- Refresh player list button
TargetsTab:CreateButton({
    Name     = "Refresh Player List",
    Callback = function()
        Rayfield:Notify({
            Title   = "Players in Server",
            Content = table.concat(buildPlayerList(), ", "),
            Duration = 5,
        })
    end,
})

TargetsTab:CreateButton({
    Name     = "Select Nearest Enemy",
    Callback = function()
        local nearest = getNearestEnemy()
        if nearest then
            Config.TargetMode   = "Specific Player"
            Config.TargetPlayer = nearest.Name
            targetPlayerObj     = nearest
            Rayfield:Notify({
                Title   = "Target Set",
                Content = "Now targeting: " .. nearest.Name,
                Duration = 3,
            })
        else
            Rayfield:Notify({
                Title   = "No Enemies",
                Content = "No other players found",
                Duration = 3,
            })
        end
    end,
})

