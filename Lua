ConfigTab:CreateToggle({
    Name         = "Auto Save on Change",
    CurrentValue = false,
    Flag         = "AutoSave",
    Callback     = function(v)
        -- Wrap all config-changing callbacks with auto save
        -- We poll this flag in a loop
        if v then
            task.spawn(function()
                while Config do
                    task.wait(10)
                    -- Only save if autosave still on
                    local flags = Rayfield.Flags
                    if flags and flags["AutoSave"] and flags["AutoSave"].Value then
                        saveConfig()
                    else
                        break
                    end
                end
            end)
            Rayfield:Notify({
                Title    = "Auto Save ON",
                Content  = "Config saves every 10 seconds",
                Duration = 3,
            })
        else
            Rayfield:Notify({
                Title    = "Auto Save OFF",
                Content  = "Remember to save manually",
                Duration = 3,
            })
        end
    end,
})

