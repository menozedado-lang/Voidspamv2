-- ═══════════════════════════════════════════
local hitRegTracked    = {}   -- [part] = { lastPos = Vector3 }
local hitRegHeartbeat  = nil
local hitRegChildAdded = nil
local hitRegChildRemov = nil
local hitRegTotalHits  = 0
local hitRegTotalShots = 0

-- Raycast params (exclude local character)
local rParams = RaycastParams.new()
rParams.FilterType = Enum.RaycastFilterType.Exclude

local function updateRaycastFilter()
    if LocalPlayer.Character then
        rParams.FilterDescendantsInstances = { LocalPlayer.Character }
    end
end
updateRaycastFilter()
LocalPlayer.CharacterAdded:Connect(updateRaycastFilter)

-- ── Hit chance roll (0–100 strength) ──
-- At 100 → always registers
-- At 0   → never registers (purely visual, no hit)
-- Between → probabilistic
local function shouldRegisterHit()
    if Config.HitRegStrength >= 100 then return true end
    if Config.HitRegStrength <= 0   then return false end
    return math.random(1, 100) <= Config.HitRegStrength
end

-- ── Track a projectile part for hit reg ──
local function hitRegTrack(obj)
    if not obj:IsA("BasePart") then return end
    hitRegTracked[obj] = { lastPos = obj.Position }
    hitRegTotalShots   = hitRegTotalShots + 1
end

local function stopHitReg()
    if hitRegHeartbeat  then hitRegHeartbeat:Disconnect()  hitRegHeartbeat  = nil end
    if hitRegChildAdded then hitRegChildAdded:Disconnect() hitRegChildAdded = nil end
    if hitRegChildRemov then hitRegChildRemov:Disconnect() hitRegChildRemov = nil end
    hitRegTracked   = {}
end

local function startHitReg()
    stopHitReg()

    -- Track new projectiles
    hitRegChildAdded = workspace.ChildAdded:Connect(function(o)
        if o.Name == "CoreProjectile" then
            hitRegTrack(o)
        elseif o.Name == "Part" then
            task.defer(function()
                if o and o.Parent and
                   o.AssemblyLinearVelocity.Magnitude > Config.HitRegSpeedThresh then
                    hitRegTrack(o)
                end
            end)
        end
    end)

    hitRegChildRemov = workspace.ChildRemoved:Connect(function(o)
        hitRegTracked[o] = nil
    end)

    hitRegHeartbeat = RunService.Heartbeat:Connect(function()
        local Void = CFrame.new(Config.VoidPos)

        -- ── Freeze enemies ──
        if Config.HitRegFreezeEnemies then
            for _, p in ipairs(playerListCache) do
                local chr = p.Character
                local hrp = chr and chr:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.CFrame                  = Void
                    hrp.AssemblyLinearVelocity  = Vector3.zero
                    hrp.AssemblyAngularVelocity = Vector3.zero
                end
            end
        end

        -- ── Hit reg raycast + void projectiles ──
        for obj, data in pairs(hitRegTracked) do
            if obj and obj.Parent then
                local currentPos = obj.Position
                local dir        = currentPos - data.lastPos

                -- Only raycast if projectile actually moved
                if dir.Magnitude > 0.01 then
                    -- Scale raycast length by hit reg strength
                    -- At 100% → full extended ray (longer = more forgiving)
                    -- At 0%   → no raycast at all
                    local rayLength  = dir.Magnitude * (1 + (Config.HitRegStrength / 100) * 4)
                    local rayDir     = dir.Unit * rayLength

                    if shouldRegisterHit() then
                        local hit = workspace:Raycast(data.lastPos, rayDir, rParams)
                        if hit then
                            hitRegTotalHits = hitRegTotalHits + 1
                            if Config.HitRegShowDebug then
                                print(string.format(
                                    "[HitReg] Hit: %s | Total: %d/%d (%.0f%%)",
                                    hit.Instance.Name,
                                    hitRegTotalHits,
                                    hitRegTotalShots,
                                    hitRegTotalShots > 0
                                        and (hitRegTotalHits / hitRegTotalShots * 100)
                                        or 0
                                ))
                            end
                        end
                    end
                end

                data.lastPos = currentPos

                -- Void the projectile
                if Config.HitRegVoidProj then
                    obj.CFrame                 = Void
                    obj.AssemblyLinearVelocity = Vector3.zero
                end
            else
                hitRegTracked[obj] = nil
            end
        end
    end)
end

-- ═══════════════════════════════════════════
-- PREDICTION STATE
-- ═══════════════════════════════════════════
local predCache    = {}
local HISTORY_SIZE = 5

local function initPredCache(player)
    predCache[player] = {
        pos      = Vector3.zero,
        vel      = Vector3.zero,
        accel    = Vector3.zero,
        smoothed = nil,
        history  = {},
    }
end

local function updatePredCacheForPlayer(player, hrp)
    local now = tick()
    local pos = hrp.Position
    if not predCache[player] then initPredCache(player) end
    local cache = predCache[player]
    local h     = cache.history
    h[#h + 1]   = { pos = pos, t = now }
    if #h > HISTORY_SIZE then table.remove(h, 1) end
    if #h >= 2 then
        local dt = h[#h].t - h[1].t
        if dt > 0 then
            local histVel = (h[#h].pos - h[1].pos) / dt
            cache.vel     = histVel * 0.65 + hrp.AssemblyLinearVelocity * 0.35
        end
    else
        cache.vel = hrp.AssemblyLinearVelocity
    end
    if #h >= 3 then
        local n   = #h
        local dt1 = h[n].t   - h[n-1].t
        local dt2 = h[n-1].t - h[n-2].t
        if dt1 > 0 and dt2 > 0 then
            local v1    = (h[n].pos   - h[n-1].pos) / dt1
            local v2    = (h[n-1].pos - h[n-2].pos) / dt2
            cache.accel = (v1 - v2) / ((dt1 + dt2) * 0.5)
        end
    end
    cache.pos = pos
end

local function getPredictedPosition(player)
    local cache = predCache[player]
    if not cache then return nil end
    local totalLead = Config.PredictionStrength + Config.PredictionLatency
    if Config.PredictionAdaptive then
        local speed = cache.vel.Magnitude
        local scale = math.clamp(1 - speed / 200, 0.4, 1.4)
        totalLead   = totalLead * scale
    end
    local predicted
    local method = Config.PredictionMethod
    if method == "Velocity Only" then
        predicted = cache.pos + cache.vel * totalLead
    elseif method == "Velocity + Accel" then
        predicted = cache.pos + cache.vel * totalLead + cache.accel * (0.5 * totalLead * totalLead)
    else
        predicted = cache.pos + cache.vel * totalLead + cache.accel * 0.5 * (0.5 * totalLead * totalLead)
    end
    local delta = predicted - cache.pos
    local mag   = delta.Magnitude
    if mag > Config.PredictionMaxLead then
        predicted = cache.pos + delta * (Config.PredictionMaxLead / mag)
    end
    local sf = Config.PredictionSmoothFactor
    if sf > 0 then
        cache.smoothed = cache.smoothed
            and cache.smoothed * sf + predicted * (1 - sf)
            or predicted
        predicted = cache.smoothed
    end
    return predicted
end

-- ═══════════════════════════════════════════
-- NEAREST ENEMY
-- ═══════════════════════════════════════════
local function getNearestEnemy()
    local now = tick()
    if now - nearestEnemyCacheTime < NEAREST_CACHE_TIME then return nearestEnemyCache end
    local myChar = LocalPlayer.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then nearestEnemyCache = nil nearestEnemyCacheTime = now return nil end
    local myPos         = myHRP.Position
    local nearest       = nil
    local nearestDistSq = math.huge
    for _, p in ipairs(playerListCache) do
        local hrp = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local dx = hrp.Position.X - myPos.X
            local dy = hrp.Position.Y - myPos.Y
            local dz = hrp.Position.Z - myPos.Z
            local dSq = dx*dx + dy*dy + dz*dz
            if dSq < nearestDistSq then nearestDistSq = dSq nearest = p end
        end
    end
    nearestEnemyCache     = nearest
    nearestEnemyCacheTime = now
    return nearest
end

-- ═══════════════════════════════════════════
-- PREDICTION SPHERE
-- ═══════════════════════════════════════════
local function updatePredSphere(pos)
    if not Config.PredictionShowSphere then
        if predSphere then predSphere:Destroy() predSphere = nil end
        return
    end
    if not predSphere then
        predSphere              = Instance.new("Part")
        predSphere.Name         = "PredSphere"
        predSphere.Shape        = Enum.PartType.Ball
        predSphere.Size         = Vector3.new(2, 2, 2)
        predSphere.Anchored     = true
        predSphere.CanCollide   = false
        predSphere.Material     = Enum.Material.Neon
        predSphere.Color        = Color3.fromRGB(255, 50, 50)
        predSphere.Transparency = 0.35
        predSphere.Parent       = workspace
    end
    if pos then predSphere.CFrame = CFrame.new(pos) end
end

local function cleanupPredSphere()
    if predSphere then predSphere:Destroy() predSphere = nil end
end

-- ═══════════════════════════════════════════
-- CONFIG SAVING / LOADING
-- ═══════════════════════════════════════════
local ConfigFolder = "unnamed"
local ConfigFile   = ConfigFolder .. "/rivals_config.json"

local SaveableKeys = {
    "Enabled","TeleportEnemies","TeleportProj","TeleportFastParts",
    "SpeedThreshold","TargetMode","TargetPlayer",
    "WeaponSpeedEnabled","WeaponSpeedPercent",
    "PredictionEnabled","PredictionMethod","PredictionStrength",
    "PredictionMaxLead","PredictionShowSphere","PredictionLatency",
    "PredictionSmoothFactor","PredictionAdaptive",
    "HitRegEnabled","HitRegStrength","HitRegFreezeEnemies",
    "HitRegVoidProj","HitRegSpeedThresh","HitRegShowDebug",
    "VoidPosX","VoidPosY","VoidPosZ",
    "AvatarVictimId","AvatarHelper","AvatarLevel","AvatarStreak",
    "AvatarElo","AvatarKeys","AvatarPremium","AvatarVerified",
    "AvatarUnlockAll","AvatarPlatform",
}

local function saveConfig()
    local ok, err = pcall(function()
        if not isfolder(ConfigFolder) then makefolder(ConfigFolder) end
        local data = {}
        for _, key in ipairs(SaveableKeys) do
            if     key == "VoidPosX" then data[key] = Config.VoidPos.X
            elseif key == "VoidPosY" then data[key] = Config.VoidPos.Y
            elseif key == "VoidPosZ" then data[key] = Config.VoidPos.Z
            else                          data[key] = Config[key] end
        end
        writefile(ConfigFile, HttpService:JSONEncode(data))
    end)
    if not ok then
        Rayfield:Notify({ Title="Save Failed", Content=tostring(err), Duration=4 })
    end
end

local function loadConfig()
    local ok, err = pcall(function()
        if not isfolder(ConfigFolder) then makefolder(ConfigFolder) end
        if not isfile(ConfigFile) then return end
        local data = HttpService:JSONDecode(readfile(ConfigFile))
        for _, key in ipairs(SaveableKeys) do
            if     key == "VoidPosX" and data[key] then Config.VoidPos = Vector3.new(data[key], Config.VoidPos.Y, Config.VoidPos.Z)
            elseif key == "VoidPosY" and data[key] then Config.VoidPos = Vector3.new(Config.VoidPos.X, data[key], Config.VoidPos.Z)
            elseif key == "VoidPosZ" and data[key] then Config.VoidPos = Vector3.new(Config.VoidPos.X, Config.VoidPos.Y, data[key])
            elseif data[key] ~= nil then Config[key] = data[key] end
        end
    end)
    if not ok then
        Rayfield:Notify({ Title="Load Failed", Content=tostring(err), Duration=4 })
    end
end

loadConfig()

-- ═══════════════════════════════════════════
-- WEAPON SPEED
-- ═══════════════════════════════════════════
local DefaultReloadLengths = { Bow=0, Daggers=0.09, Slingshot=0 }
local WhitelistedItems     = {"Bow","Daggers","Slingshot"}

local function applyWeaponSpeed(percent)
    pcall(function()
        local ItemLibrary = require(ReplicatedStorage.Modules.ItemLibrary)
        local Items       = rawget(ItemLibrary, "Items")
        if not Items then return end
        local multiplier = (300 - percent) / 200
        for _, Item in Items do
            local Name = Item.Name
            if not table.find(WhitelistedItems, Name) then continue end
            if Item["ReloadLength"] == nil then continue end
            local base   = DefaultReloadLengths[Name] or 0
            local newVal = math.clamp(base * multiplier, 0, base * 3)
            if percent >= 300 then newVal = (Name == "Daggers") and 0.001 or 0 end
            rawset(Item, "ReloadLength", newVal)
        end
    end)
end

local function resetWeaponSpeed()
    pcall(function()
        local ItemLibrary = require(ReplicatedStorage.Modules.ItemLibrary)
        local Items       = rawget(ItemLibrary, "Items")
        if not Items then return end
        for _, Item in Items do
            local Name = Item.Name
            if not table.find(WhitelistedItems, Name) then continue end
            if Item["ReloadLength"] == nil then continue end
            rawset(Item, "ReloadLength", DefaultReloadLengths[Name] or 0)
        end
    end)
end

