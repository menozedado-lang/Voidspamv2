-- PREDICTION
-- ═══════════════════════════════════════════
local predCache    = {}
local HISTORY_SIZE = 5
local predSphere   = nil

local function initPredCache(p)
    predCache[p] = { pos=Vector3.zero, vel=Vector3.zero, accel=Vector3.zero, smoothed=nil, history={} }
end

local function updatePredCacheForPlayer(p, hrp)
    local now=tick() local pos=hrp.Position
    if not predCache[p] then initPredCache(p) end
    local c=predCache[p] local h=c.history
    h[#h+1]={pos=pos,t=now}
    if #h>HISTORY_SIZE then table.remove(h,1) end
    if #h>=2 then
        local dt=h[#h].t-h[1].t
        if dt>0 then c.vel=(h[#h].pos-h[1].pos)/dt*0.65+hrp.AssemblyLinearVelocity*0.35 end
    else c.vel=hrp.AssemblyLinearVelocity end
    if #h>=3 then
        local n=#h local dt1=h[n].t-h[n-1].t local dt2=h[n-1].t-h[n-2].t
        if dt1>0 and dt2>0 then
            c.accel=((h[n].pos-h[n-1].pos)/dt1-(h[n-1].pos-h[n-2].pos)/dt2)/((dt1+dt2)*0.5)
        end
    end
    c.pos=pos
end

local function getPredictedPosition(p)
    local c=predCache[p] if not c then return nil end
    local tl=Config.PredictionStrength+Config.PredictionLatency
    if Config.PredictionAdaptive then
        local sc=math.clamp(1-c.vel.Magnitude/200,0.4,1.4) tl=tl*sc
    end
    local pred
    if Config.PredictionMethod=="Velocity Only" then
        pred=c.pos+c.vel*tl
    elseif Config.PredictionMethod=="Velocity + Accel" then
        pred=c.pos+c.vel*tl+c.accel*(0.5*tl*tl)
    else
        pred=c.pos+c.vel*tl+c.accel*0.5*(0.5*tl*tl)
    end
    local delta=pred-c.pos local mag=delta.Magnitude
    if mag>Config.PredictionMaxLead then pred=c.pos+delta*(Config.PredictionMaxLead/mag) end
    local sf=Config.PredictionSmoothFactor
    if sf>0 then
        c.smoothed=c.smoothed and c.smoothed*sf+pred*(1-sf) or pred
        pred=c.smoothed
    end
    return pred
end

local function updatePredSphere(pos)
    if not Config.PredictionShowSphere then
        if predSphere then predSphere:Destroy() predSphere=nil end return
    end
    if not predSphere then
        predSphere=Instance.new("Part") predSphere.Name="PredSphere"
        predSphere.Shape=Enum.PartType.Ball predSphere.Size=Vector3.new(2,2,2)
        predSphere.Anchored=true predSphere.CanCollide=false
        predSphere.Material=Enum.Material.Neon predSphere.Color=Color3.fromRGB(255,50,50)
        predSphere.Transparency=0.35 predSphere.Parent=workspace
    end
    if pos then predSphere.CFrame=CFrame.new(pos) end
end

local function cleanupPredSphere()
    if predSphere then predSphere:Destroy() predSphere=nil end
end

-- ═══════════════════════════════════════════
-- HIT REG (multi-ray, 75-79%+)
-- ═══════════════════════════════════════════
local tracked      = {}
local hitTotal     = 0
local shotTotal    = 0
local hitRegConn   = nil
local hrChildAdd   = nil
local hrChildRem   = nil

local function multiRaycast(origin, direction, strength)
    local ext=1+(strength/100)*4
    local mainDir=direction*ext
    local hit=workspace:Raycast(origin,mainDir,rParams)
    if hit then return hit end
    local spread=(strength/100)*0.6
    local perp1=Vector3.new(-direction.Z,0,direction.X).Unit*spread
    local perp2=Vector3.new(direction.Z,0,-direction.X).Unit*spread
    local up=Vector3.new(0,spread,0)
    for _,off in ipairs({perp1,perp2,up,-up}) do
        local h=workspace:Raycast(origin+off,mainDir,rParams)
        if h then return h end
    end
    return workspace:Raycast(origin,mainDir*2,rParams)
end

local function shouldFire()
    if Config.HitRegStrength>=100 then return true end
    if Config.HitRegStrength<=0   then return false end
    return math.random(1,100)<=Config.HitRegStrength
end

local function trackHR(obj)
    if not obj:IsA("BasePart") then return end
    tracked[obj]={lastPos=obj.Position,lastPos2=obj.Position}
    shotTotal=shotTotal+1
end

local function stopHitReg()
    if hitRegConn then hitRegConn:Disconnect() hitRegConn=nil end
    if hrChildAdd then hrChildAdd:Disconnect() hrChildAdd=nil end
    if hrChildRem then hrChildRem:Disconnect() hrChildRem=nil end
    tracked={}
end

local function startHitReg()
    stopHitReg()
    hrChildAdd=workspace.ChildAdded:Connect(function(o)
        if o.Name=="CoreProjectile" then trackHR(o)
        elseif o.Name=="Part" then
            task.defer(function()
                if o and o.Parent and o.AssemblyLinearVelocity.Magnitude>Config.HRSpeedThresh then
                    trackHR(o) end
            end)
        end
    end)
    hrChildRem=workspace.ChildRemoved:Connect(function(o) tracked[o]=nil end)
    hitRegConn=RunService.Heartbeat:Connect(function()
        -- Freeze enemies (shared with weapon chaos)
        if Config.FreezeEnemies then
            for _,p in ipairs(playerCache) do
                local hrp=p.Character and p.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.CFrame=Void
                    hrp.AssemblyLinearVelocity=Vector3.zero
                    hrp.AssemblyAngularVelocity=Vector3.zero
                end
            end
        end
        -- Multi-ray hit reg
        for obj,data in pairs(tracked) do
            if obj and obj.Parent then
                local cur=obj.Position
                local dir=cur-data.lastPos
                if dir.Magnitude>0.01 and shouldFire() then
                    local hit=multiRaycast(data.lastPos,dir,Config.HitRegStrength)
                    if hit then
                        hitTotal=hitTotal+1
                        if Config.ShowDebug then
                            print(string.format("[HitReg] Hit: %s | %d/%d (%.0f%%)",
                                hit.Instance.Name,hitTotal,shotTotal,
                                shotTotal>0 and hitTotal/shotTotal*100 or 0))
                        end
                    end
                end
                -- look-ahead ray
                if (cur-data.lastPos2).Magnitude>0.01 and shouldFire() then
                    multiRaycast(data.lastPos2,cur-data.lastPos2,Config.HitRegStrength)
                end
                data.lastPos2=data.lastPos data.lastPos=cur
                if Config.VoidProjectiles then
                    obj.CFrame=Void obj.AssemblyLinearVelocity=Vector3.zero
                end
            else tracked[obj]=nil end
        end
    end)
end

