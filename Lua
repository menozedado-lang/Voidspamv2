local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- ═══════════════════════════════════════════
-- SERVICES
-- ═══════════════════════════════════════════
local RunService  = game:GetService("RunService")
local Players     = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- ═══════════════════════════════════════════
-- STATE
-- ═══════════════════════════════════════════
local Config = {
    Enabled          = false,
    TeleportEnemies  = true,
    TeleportProj     = true,
    TeleportFastParts= true,
    VoidPos          = Vector3.new(9000, 9000, 9000),
    WhitelistSelf    = true,
    TargetMode       = "All Enemies",
    TargetPlayer     = "",
    SpeedThreshold   = 50,
}

local trackedParts = {}
local heartbeatConn = nil
local childAddedConn = nil
local childRemovedConn = nil
local targetPlayerObj = nil

-- ═══════════════════════════════════════════
-- CORE BYPASS FUNCTIONS
-- ═══════════════════════════════════════════
local function getVoidCFrame()
    return CFrame.new(Config.VoidPos)
end

local function shouldTargetPlayer(p)
    if p == LocalPlayer then return false end
    if Config.TargetMode == "All Enemies" then
        return true
    elseif Config.TargetMode == "Specific Player" then
        return targetPlayerObj ~= nil and p == targetPlayerObj
    elseif Config.TargetMode == "Nearest Enemy" then
        -- handled separately
        return true
    end
    return true
end

local function getNearestEnemy()
    local myChar = LocalPlayer.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end
    local nearest = nil
    local nearestDist = math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local chr = p.Character
        local hrp = chr and chr:FindFirstChild("HumanoidRootPart")
        if hrp then
            local d = (hrp.Position - myHRP.Position).Magnitude
            if d < nearestDist then
                nearestDist = d
                nearest = p
            end
        end
    end
    return nearest
end

-- ═══════════════════════════════════════════
-- START / STOP
-- ═══════════════════════════════════════════
local function stopBypass()
    if heartbeatConn   then heartbeatConn:Disconnect();   heartbeatConn   = nil end
    if childAddedConn  then childAddedConn:Disconnect();  childAddedConn  = nil end
    if childRemovedConn then childRemovedConn:Disconnect(); childRemovedConn = nil end
    trackedParts = {}
end

local function startBypass()
    stopBypass()

    -- Track projectiles added to workspace
    childAddedConn = workspace.ChildAdded:Connect(function(o)
        if not o:IsA("BasePart") then return end
        if o.Name == "CoreProjectile" then
            trackedParts[o] = true
        elseif o.Name == "Part" then
            task.defer(function()
                if o and o.Parent and o.AssemblyLinearVelocity.Magnitude > Config.SpeedThreshold then
                    trackedParts[o] = true
                end
            end)
        end
    end)

    childRemovedConn = workspace.ChildRemoved:Connect(function(o)
        trackedParts[o] = nil
    end)

    heartbeatConn = RunService.Heartbeat:Connect(function()
        pcall(function()
            local voidCF = getVoidCFrame()

            -- ── Teleport enemies ──
            if Config.TeleportEnemies then
                local nearestOnly = Config.TargetMode == "Nearest Enemy" and getNearestEnemy() or nil

                for _, p in ipairs(Players:GetPlayers()) do
                    if p == LocalPlayer then continue end

                    local skip = false
                    if Config.TargetMode == "Nearest Enemy" then
                        skip = (p ~= nearestOnly)
                    elseif Config.TargetMode == "Specific Player" then
                        skip = (p ~= targetPlayerObj)
                    end

                    if not skip and p.Character then
                        local h = p.Character:FindFirstChild("HumanoidRootPart")
                        if h then
                            h.CFrame                  = voidCF
                            h.AssemblyLinearVelocity  = Vector3.zero
                            h.AssemblyAngularVelocity = Vector3.zero
                        end
                    end
                end
            end

            -- ── Teleport CoreProjectile ──
            if Config.TeleportProj then
                for _, o in ipairs(workspace:GetChildren()) do
                    if o.Name == "CoreProjectile" and o:IsA("BasePart") then
                        o.CFrame                 = voidCF
                        o.AssemblyLinearVelocity = Vector3.zero
                    end
                end
            end

            -- ── Teleport tracked fast parts ──
            if Config.TeleportFastParts then
                for p, _ in pairs(trackedParts) do
                    if p and p.Parent then
                        p.CFrame                 = voidCF
                        p.AssemblyLinearVelocity = Vector3.zero
                    else
                        trackedParts[p] = nil
                    end
                end
            end
        end)
    end)
end

