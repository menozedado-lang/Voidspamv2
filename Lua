LP.CharacterAdded:Connect(function()
    tracked    = {}
    playerCache = {}
    task.wait(0.5)
    rebuildCache()
    updateFilter()
    if Config.HitRegEnabled    then task.wait(0.5) startHitReg()    end
    if Config.AntiRiotEnabled  then task.wait(0.5) startAntiRiot()  end
    if Config.VoidJitterEnabled then task.wait(0.5) startVoidJitter() end
    applyAllWeaponBypasses()
end)

