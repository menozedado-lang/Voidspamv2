-- NEAREST / TARGET HELPERS
-- ═══════════════════════════════════════════
local nearestEnemyCache     = nil
local nearestEnemyCacheTime = 0
local targetPlayerObj       = nil

local function getNearestEnemy()
    local now = tick()
    if now - nearestEnemyCacheTime < NEAREST_CACHE_TIME then return nearestEnemyCache end
    local myChar = LP.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then nearestEnemyCache=nil nearestEnemyCacheTime=now return nil end
    local myPos=myHRP.Position local nearest,dSqB=nil,math.huge
    for _,p in ipairs(playerCache) do
        local hrp=p.Character and p.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local dx=hrp.Position.X-myPos.X
            local dy=hrp.Position.Y-myPos.Y
            local dz=hrp.Position.Z-myPos.Z
            local dSq=dx*dx+dy*dy+dz*dz
            if dSq<dSqB then dSqB=dSq nearest=p end
        end
    end
    nearestEnemyCache=nearest nearestEnemyCacheTime=now
    return nearest
end

-- Priority target for void spam
local function getPriorityTarget()
    if #playerCache == 0 then return nil end
    local mode = Config.VoidSpamPriority
    if mode == "Closest" then
        return getNearestEnemy()
    elseif mode == "LowHP" then
        local best, bestHP = nil, math.huge
        for _, p in ipairs(playerCache) do
            local hum = p.Character and p.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health < bestHP then bestHP=hum.Health best=p end
        end
        return best
    elseif mode == "HighHP" then
        local best, bestHP = nil, -math.huge
        for _, p in ipairs(playerCache) do
            local hum = p.Character and p.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > bestHP then bestHP=hum.Health best=p end
        end
        return best
    end
    return getNearestEnemy()
end

local function shouldTargetPlayer(p)
    if p==LP then return false end
    if Config.TargetMode=="Specific Player" then return targetPlayerObj~=nil and p==targetPlayerObj end
    return true
end

-- Detect what weapon a player is holding
local function getPlayerWeapon(p)
    local chr = p and p.Character
    if not chr then return "Unknown" end
    for _, obj in ipairs(chr:GetChildren()) do
        if obj:IsA("Tool") then return obj.Name end
    end
    return "Unknown"
end

