-- AVATAR CHANGER
-- ═══════════════════════════════════════════
local platformImages = {
    DESKTOP = "rbxassetid://17136633356",
    MOBILE  = "rbxassetid://17136633510",
    CONSOLE = "rbxassetid://17136633629",
    VR      = "rbxassetid://17136765745",
}

local avatarActive      = false
local avatarRenderConn  = nil
local avatarOldNamecall = nil
local avatarDecodedData = nil

local function applyCharacterAppearance(plr, decoded)
    pcall(function()
        local appearance = Players:GetCharacterAppearanceAsync(decoded.id)
        local char       = plr.Character
        if not char then return end
        for _, v in ipairs(char:GetChildren()) do
            if v:IsA("Accessory") or v:IsA("Shirt") or
               v:IsA("Pants")     or v:IsA("BodyColors") then v:Destroy() end
        end
        for _, v in ipairs(appearance:GetChildren()) do
            if v:IsA("Shirt") or v:IsA("Pants") or v:IsA("BodyColors") then
                v.Parent = char
            elseif v:IsA("Accessory") then
                char:WaitForChild("Humanoid"):AddAccessory(v)
            end
        end
        local head = char:WaitForChild("Head")
        if head:FindFirstChild("face") then head.face:Destroy() end
        if appearance:FindFirstChild("face") then
            appearance.face.Parent = head
        else
            local face        = Instance.new("Decal")
            face.Face         = Enum.NormalId.Front
            face.Name         = "face"
            face.Texture      = "rbxasset://textures/face.png"
            face.Transparency = 0
            face.Parent       = head
        end
        local parent = char.Parent
        char.Parent  = nil
        char.Parent  = parent
    end)
end

local function stopAvatarChanger()
    avatarActive = false
    if avatarRenderConn then avatarRenderConn:Disconnect() avatarRenderConn = nil end
    if avatarOldNamecall then
        pcall(function() hookmetamethod(game, "__index", avatarOldNamecall) end)
        avatarOldNamecall = nil
    end
    avatarDecodedData = nil
    Rayfield:Notify({ Title="Avatar Changer", Content="Stopped. Rejoin to fully restore.", Duration=4 })
end

local function startAvatarChanger()
    if avatarActive then stopAvatarChanger() end
    if Config.AvatarVictimId == 0 then
        Rayfield:Notify({ Title="Avatar Changer", Content="Enter a valid Victim User ID first!", Duration=4 })
        return
    end
    local fetchOk, fetchErr = pcall(function()
        local raw         = game:HttpGet("https://users.roblox.com/v1/users/"..Config.AvatarVictimId, true)
        avatarDecodedData = HttpService:JSONDecode(raw)
    end)
    if not fetchOk or not avatarDecodedData or not avatarDecodedData.name then
        Rayfield:Notify({ Title="Avatar Changer", Content="Failed: "..tostring(fetchErr), Duration=5 })
        return
    end
    local decoded  = avatarDecodedData
    local platform = tostring(Config.AvatarPlatform):upper()
    local friend   = Config.AvatarHelper ~= "" and Players:FindFirstChild(Config.AvatarHelper) or LocalPlayer
    if not friend then
        Rayfield:Notify({ Title="Avatar Changer", Content="Helper not found", Duration=4 })
        return
    end
    pcall(function()
        friend.Name                  = decoded.name
        friend.UserId                = decoded.id
        friend.CharacterAppearanceId = decoded.id
        friend.DisplayName           = decoded.displayName
    end)
    if not friend.Character then friend.CharacterAdded:Wait() end
    local char = friend.Character
    char:WaitForChild("Humanoid")
    pcall(function()
        char.Name                 = decoded.name
        char.Humanoid.DisplayName = decoded.displayName
    end)
    pcall(function()
        local plrObj = Players:WaitForChild(decoded.name)
        plrObj:SetAttribute("Level", tonumber(Config.AvatarLevel))
        plrObj:SetAttribute("StatisticDuelsWinStreak", tonumber(Config.AvatarStreak))
        local cl = plrObj:WaitForChild("CustomLeaderstats")
        if cl:FindFirstChild("Level") then cl.Level.Value = tonumber(Config.AvatarLevel) end
        if cl:FindFirstChild("Win Streak") then cl["Win Streak"].Value = tonumber(Config.AvatarStreak) end
        if tonumber(Config.AvatarElo) > 0 then
            plrObj:SetAttribute("DisplayELO", tonumber(Config.AvatarElo))
        end
    end)
    applyCharacterAppearance(friend, decoded)
    friend.CharacterAdded:Connect(function()
        if not avatarActive then return end
        task.wait(0.5)
        applyCharacterAppearance(friend, decoded)
    end)
    pcall(function()
        local spoofed = Players:FindFirstChild(decoded.name) or friend
        avatarOldNamecall = hookmetamethod(game, "__index", function(self, key)
            if self == spoofed then
                if key == "MembershipType" and Config.AvatarPremium then return Enum.MembershipType.Premium end
                if key == "HasVerifiedBadge" and Config.AvatarVerified then return true end
            end
            return avatarOldNamecall(self, key)
        end)
    end)

    local cachedCtrl     = nil
    local cachedCtrlTime = 0

    avatarRenderConn = RunService.RenderStepped:Connect(function()
        avatarFrameCount = avatarFrameCount + 1
        if avatarFrameCount % AVATAR_UPDATE_RATE ~= 0 then return end
        pcall(function()
            local now = tick()
            if not cachedCtrl or now - cachedCtrlTime > 2 then
                local plrInst = Players:FindFirstChild(decoded.name)
                cachedCtrl    = plrInst
                    and plrInst.Character
                    and plrInst.Character:FindFirstChild("HumanoidRootPart")
                    and plrInst.Character.HumanoidRootPart:FindFirstChild("Nametag")
                    and plrInst.Character.HumanoidRootPart.Nametag:FindFirstChild("Frame")
                    and plrInst.Character.HumanoidRootPart.Nametag.Frame:FindFirstChild("Player")
                    and plrInst.Character.HumanoidRootPart.Nametag.Frame.Player:FindFirstChild("Controls")
                cachedCtrlTime = now
            end
            if cachedCtrl then cachedCtrl.Image = platformImages[platform] or platformImages.DESKTOP end
            if tonumber(Config.AvatarKeys) > 0 then
                local currency = LocalPlayer.PlayerGui
                    and LocalPlayer.PlayerGui:FindFirstChild("MainGui")
                    and LocalPlayer.PlayerGui.MainGui:FindFirstChild("MainFrame")
                    and LocalPlayer.PlayerGui.MainGui.MainFrame:FindFirstChild("Lobby")
                    and LocalPlayer.PlayerGui.MainGui.MainFrame.Lobby:FindFirstChild("Currency")
                    and LocalPlayer.PlayerGui.MainGui.MainFrame.Lobby.Currency:FindFirstChild("Container")
                if currency then
                    for _, v in ipairs(currency:GetChildren()) do
                        if v:FindFirstChild("Icon") and v.Icon.Image == "rbxassetid://17860673529" then
                            if v:FindFirstChild("Title") then v.Title.Text = tostring(Config.AvatarKeys) end
                        end
                    end
                end
            end
        end)
    end)
    avatarActive = true
    Rayfield:Notify({ Title="Avatar Changer", Content="Spoofing as: "..decoded.name, Duration=4 })
end

-- ═══════════════════════════════════════════
-- CORE BYPASS
-- ═══════════════════════════════════════════
local function shouldTargetPlayer(p)
    if p == LocalPlayer then return false end
    if Config.TargetMode == "Specific Player" then
        return targetPlayerObj ~= nil and p == targetPlayerObj
    end
    return true
end

local function stopBypass()
    if heartbeatConn    then heartbeatConn:Disconnect()    heartbeatConn    = nil end
    if childAddedConn   then childAddedConn:Disconnect()   childAddedConn   = nil end
    if childRemovedConn then childRemovedConn:Disconnect() childRemovedConn = nil end
    trackedParts          = {}
    predCache             = {}
    nearestEnemyCache     = nil
    nearestEnemyCacheTime = 0
    cleanupPredSphere()
end

local function startBypass()
    stopBypass()
    childAddedConn = workspace.ChildAdded:Connect(function(o)
        if not o:IsA("BasePart") then return end
        if o.Name == "CoreProjectile" then
            trackedParts[o] = true
        elseif o.Name == "Part" then
            task.defer(function()
                if o and o.Parent and o.AssemblyLinearVelocity.Magnitude > Config.SpeedThreshold then
                    trackedParts[o] = true
                end
            end)
        end
    end)
    childRemovedConn = workspace.ChildRemoved:Connect(function(o)
        trackedParts[o] = nil
    end)
    heartbeatConn = RunService.Heartbeat:Connect(function()
        frameCount = frameCount + 1

        if Config.PredictionEnabled and frameCount % PRED_UPDATE_RATE == 0 then
            for _, p in ipairs(playerListCache) do
                local hrp = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
                if hrp then updatePredCacheForPlayer(p, hrp) end
            end
        end

        local nearestOnly = Config.TargetMode == "Nearest Enemy" and getNearestEnemy() or nil

        if Config.PredictionEnabled and Config.PredictionShowSphere and frameCount % 3 == 0 then
            local predTarget = nearestOnly
                or (Config.TargetMode == "Specific Player" and targetPlayerObj)
                or nearestEnemyCache
            if predTarget then updatePredSphere(getPredictedPosition(predTarget)) end
        elseif not Config.PredictionEnabled then
            cleanupPredSphere()
        end

        if Config.TeleportEnemies then
            local vx = Config.VoidPos.X
            local vy = Config.VoidPos.Y
            local vz = Config.VoidPos.Z
            for _, p in ipairs(playerListCache) do
                if not shouldTargetPlayer(p) then continue end
                local skip = false
                if Config.TargetMode == "Nearest Enemy" then skip = p ~= nearestOnly
                elseif Config.TargetMode == "Specific Player" then skip = p ~= targetPlayerObj end
                if not skip and p.Character then
                    local h = p.Character:FindFirstChild("HumanoidRootPart")
                    if h then
                        if Config.PredictionEnabled then
                            local pred = getPredictedPosition(p)
                            h.CFrame = pred and CFrame.new(pred.X, vy, pred.Z) or CFrame.new(vx, vy, vz)
                        else
                            h.CFrame = CFrame.new(vx, vy, vz)
                        end
                        h.AssemblyLinearVelocity  = Vector3.zero
                        h.AssemblyAngularVelocity = Vector3.zero
                    end
                end
            end
        end

        if Config.TeleportProj or Config.TeleportFastParts then
            local voidCF = CFrame.new(Config.VoidPos)
            for part in pairs(trackedParts) do
                if part and part.Parent then
                    local isProj = part.Name == "CoreProjectile"
                    if (isProj and Config.TeleportProj) or (not isProj and Config.TeleportFastParts) then
                        part.CFrame                 = voidCF
                        part.AssemblyLinearVelocity = Vector3.zero
                    end
                else
                    trackedParts[part] = nil
                end
            end
        end
    end)
end

