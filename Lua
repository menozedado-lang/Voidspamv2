local platformImages={DESKTOP="rbxassetid://17136633356",MOBILE="rbxassetid://17136633510",CONSOLE="rbxassetid://17136633629",VR="rbxassetid://17136765745"}
local avatarActive=false local avatarRenderConn=nil local avatarOldNC=nil local avatarData=nil

local function applyCharAppearance(plr,decoded)
    pcall(function()
        local app=Players:GetCharacterAppearanceAsync(decoded.id)
        local char=plr.Character if not char then return end
        for _,v in ipairs(char:GetChildren()) do
            if v:IsA("Accessory") or v:IsA("Shirt") or v:IsA("Pants") or v:IsA("BodyColors") then v:Destroy() end
        end
        for _,v in ipairs(app:GetChildren()) do
            if v:IsA("Shirt") or v:IsA("Pants") or v:IsA("BodyColors") then v.Parent=char
            elseif v:IsA("Accessory") then char:WaitForChild("Humanoid"):AddAccessory(v) end
        end
        local head=char:WaitForChild("Head")
        if head:FindFirstChild("face") then head.face:Destroy() end
        if app:FindFirstChild("face") then app.face.Parent=head
        else
            local f=Instance.new("Decal") f.Face=Enum.NormalId.Front f.Name="face"
            f.Texture="rbxasset://textures/face.png" f.Transparency=0 f.Parent=head
        end
        local parent=char.Parent char.Parent=nil char.Parent=parent
    end)
end

local function stopAvatar()
    avatarActive=false
    if avatarRenderConn then avatarRenderConn:Disconnect() avatarRenderConn=nil end
    if avatarOldNC then pcall(function() hookmetamethod(game,"__index",avatarOldNC) end) avatarOldNC=nil end
    avatarData=nil
    Rayfield:Notify({Title="Avatar",Content="Stopped. Rejoin to revert.",Duration=4})
end

local function startAvatar()
    if avatarActive then stopAvatar() end
    if Config.AvatarVictimId==0 then
        Rayfield:Notify({Title="Avatar",Content="Enter a valid User ID first!",Duration=4}) return
    end
    local ok,err=pcall(function()
        local raw=game:HttpGet("https://users.roblox.com/v1/users/"..Config.AvatarVictimId,true)
        avatarData=HttpService:JSONDecode(raw)
    end)
    if not ok or not avatarData or not avatarData.name then
        Rayfield:Notify({Title="Avatar",Content="Fetch failed: "..tostring(err),Duration=5}) return
    end
    local decoded=avatarData local platform=tostring(Config.AvatarPlatform):upper()
    local friend=Config.AvatarHelper~="" and Players:FindFirstChild(Config.AvatarHelper) or LP
    if not friend then Rayfield:Notify({Title="Avatar",Content="Helper not found",Duration=4}) return end
    pcall(function()
        friend.Name=decoded.name friend.UserId=decoded.id
        friend.CharacterAppearanceId=decoded.id friend.DisplayName=decoded.displayName
    end)
    if not friend.Character then friend.CharacterAdded:Wait() end
    local char=friend.Character char:WaitForChild("Humanoid")
    pcall(function() char.Name=decoded.name char.Humanoid.DisplayName=decoded.displayName end)
    pcall(function()
        local po=Players:WaitForChild(decoded.name)
        po:SetAttribute("Level",tonumber(Config.AvatarLevel))
        po:SetAttribute("StatisticDuelsWinStreak",tonumber(Config.AvatarStreak))
        local cl=po:WaitForChild("CustomLeaderstats")
        if cl:FindFirstChild("Level") then cl.Level.Value=tonumber(Config.AvatarLevel) end
        if cl:FindFirstChild("Win Streak") then cl["Win Streak"].Value=tonumber(Config.AvatarStreak) end
        if tonumber(Config.AvatarElo)>0 then po:SetAttribute("DisplayELO",tonumber(Config.AvatarElo)) end
    end)
    applyCharAppearance(friend,decoded)
    friend.CharacterAdded:Connect(function()
        if not avatarActive then return end task.wait(0.5) applyCharAppearance(friend,decoded)
    end)
    pcall(function()
        local sp=Players:FindFirstChild(decoded.name) or friend
        avatarOldNC=hookmetamethod(game,"__index",function(self,key)
            if self==sp then
                if key=="MembershipType" and Config.AvatarPremium then return Enum.MembershipType.Premium end
                if key=="HasVerifiedBadge" and Config.AvatarVerified then return true end
            end
            return avatarOldNC(self,key)
        end)
    end)
    local cachedCtrl,cachedCtrlTime=nil,0
    avatarRenderConn=RunService.RenderStepped:Connect(function()
        avatarFrameCount=avatarFrameCount+1
        if avatarFrameCount%AVATAR_UPDATE_RATE~=0 then return end
        pcall(function()
            local now=tick()
            if not cachedCtrl or now-cachedCtrlTime>2 then
                local pi=Players:FindFirstChild(decoded.name)
                cachedCtrl=pi and pi.Character and pi.Character:FindFirstChild("HumanoidRootPart")
                    and pi.Character.HumanoidRootPart:FindFirstChild("Nametag")
                    and pi.Character.HumanoidRootPart.Nametag:FindFirstChild("Frame")
                    and pi.Character.HumanoidRootPart.Nametag.Frame:FindFirstChild("Player")
                    and pi.Character.HumanoidRootPart.Nametag.Frame.Player:FindFirstChild("Controls")
                cachedCtrlTime=now
            end
            if cachedCtrl then cachedCtrl.Image=platformImages[platform] or platformImages.DESKTOP end
            if tonumber(Config.AvatarKeys)>0 then
                local currency=LP.PlayerGui and LP.PlayerGui:FindFirstChild("MainGui")
                    and LP.PlayerGui.MainGui:FindFirstChild("MainFrame")
                    and LP.PlayerGui.MainGui.MainFrame:FindFirstChild("Lobby")
                    and LP.PlayerGui.MainGui.MainFrame.Lobby:FindFirstChild("Currency")
                    and LP.PlayerGui.MainGui.MainFrame.Lobby.Currency:FindFirstChild("Container")
                if currency then
                    for _,v in ipairs(currency:GetChildren()) do
