-- ═══════════════════════════════════════════
-- ORBIT RAGEBOT (Kiciahook Premium style)
-- ═══════════════════════════════════════════
local orbitConn         = nil
local orbitLastShot     = 0
local orbitLastTP       = 0
local orbitAngle        = 0

-- Smart orbit: auto-adjusts radius + speed based on enemy weapon
local function getSmartOrbitParams(target)
    if not Config.OrbitSmartMode then
        return Config.OrbitSpeed, Config.OrbitRadius
    end
    local weapon = getPlayerWeapon(target)
    local name   = weapon:lower()
    if name:find("sniper") then
        return 80, 12   -- faster + wider vs sniper
    elseif name:find("shotgun") then
        return 120, 15  -- very fast + very wide vs shotgun
    elseif name:find("melee") or name:find("sword") or name:find("dagger") or name:find("knife") then
        return 60, 6    -- stay close to counter-melee
    elseif name:find("sling") then
        return 90, 10   -- fast orbit vs slingshot
    elseif name:find("bow") then
        return 70, 11   -- medium vs bow
    else
        return Config.OrbitSpeed, Config.OrbitRadius
    end
end

-- Check if enemy has riot shield (for orbit avoidance)
local function hasRiotShield(p)
    local chr=p and p.Character if not chr then return false end
    for _,obj in ipairs(chr:GetChildren()) do
        if obj:IsA("Tool") and (obj.Name:lower():find("riot") or obj.Name:lower():find("shield")) then return true end
    end
    return false
end

-- Check if there are incoming projectiles near local player
local function detectIncomingProjectile()
    local myChar=LP.Character
    local myHRP=myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return false end
    for _,obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("BasePart") and (obj.Name=="CoreProjectile" or obj.Name=="Part") then
            local vel=obj.AssemblyLinearVelocity
            if vel.Magnitude>50 then
                local toMe=(myHRP.Position-obj.Position)
                local dot=toMe.Unit:Dot(vel.Unit)
                local dist=toMe.Magnitude
                if dot>0.7 and dist<30 then return true end
            end
        end
    end
    return false
end

local function stopOrbitRagebot()
    if orbitConn then orbitConn:Disconnect() orbitConn=nil end
end

local function startOrbitRagebot()
    stopOrbitRagebot()
    orbitAngle = 0

    orbitConn = RunService.Heartbeat:Connect(function(dt)
        local myChar = LP.Character
        local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end

        local target = getNearestEnemy()
        if not target then return end

        local targetChr = target.Character
        local targetHRP = targetChr and targetChr:FindFirstChild("HumanoidRootPart")
        if not targetHRP then return end

        -- Anti-Riot: skip if target has riot shield and OrbitAntiRiot on
        if Config.OrbitAntiRiot and hasRiotShield(target) then
            -- Orbit away from riot shield user instead
            orbitAngle = orbitAngle + 180
        end

        local speed, radius = getSmartOrbitParams(target)

        -- Anti-Projectile: sidestep if incoming projectile detected
        if Config.OrbitAntiProjectile and detectIncomingProjectile() then
            orbitAngle = orbitAngle + 90  -- quick quarter-turn dodge
            Rayfield:Notify({Title="Orbit",Content="⚡ Projectile dodge!",Duration=1})
        end

        -- Advance orbit angle
        orbitAngle = (orbitAngle + speed * dt) % 360

        local rad = math.rad(orbitAngle)
        local offsetX = math.cos(rad) * radius
        local offsetZ = math.sin(rad) * radius

        local orbitPos = targetHRP.Position + Vector3.new(offsetX, 0, offsetZ)

        -- TP Delay check
        local now = tick()
        if now - orbitLastTP < Config.OrbitTPDelay then return end
        orbitLastTP = now

        -- Resolver: if OrbitResolver on, add slight random angle offset
        -- to make our position harder to predict for enemy scripts
        if Config.OrbitResolver then
            local jitter = math.random(-15, 15)
            orbitAngle   = orbitAngle + jitter
        end

        -- Teleport to orbit position
        myHRP.CFrame = CFrame.new(orbitPos)
        myHRP.AssemblyLinearVelocity = Vector3.zero

        -- Aura: void the target while orbiting
        if Config.OrbitAura then
            targetHRP.CFrame                  = Void
            targetHRP.AssemblyLinearVelocity  = Vector3.zero
            targetHRP.AssemblyAngularVelocity = Vector3.zero
        end

        -- Strike on melee: if target is close and using melee weapon
        if Config.OrbitStrikeOnMelee then
            local weapon = getPlayerWeapon(target):lower()
            local dist   = (myHRP.Position - targetHRP.Position).Magnitude
            if (weapon:find("melee") or weapon:find("sword") or weapon:find("dagger") or weapon:find("knife"))
                and dist < 10 then
                -- Snap to them and attempt melee input
                myHRP.CFrame = CFrame.new(targetHRP.Position + Vector3.new(0, 0, 2))
                task.wait(0.05)
                -- Simulate click (melee attack)
                pcall(function()
                    local tool = myChar:FindFirstChildOfClass("Tool")
                    if tool and tool:FindFirstChild("Handle") then
                        local remote = tool:FindFirstChild("RemoteEvent") or tool:FindFirstChild("RemoteFunction")
                        if remote then remote:FireServer() end
                    end
                end)
            end
        end

        -- Shot interval
        if now - orbitLastShot >= Config.OrbitShotInterval then
            orbitLastShot = now
            -- Attempt to fire current tool
            pcall(function()
                local tool = myChar:FindFirstChildOfClass("Tool")
                if tool then
                    local remote = tool:FindFirstChild("RemoteEvent")
                    if remote then remote:FireServer() end
                end
            end)
        end
    end)
end

-- ═══════════════════════════════════════════
-- VOID SPAM RAGEBOT (Unnamed Enhancement style)
-- ═══════════════════════════════════════════
local voidSpamConn = nil

local function stopVoidSpam()
    if voidSpamConn then voidSpamConn:Disconnect() voidSpamConn=nil end
    Config.VoidSpamRunning = false
end

local function voidSpamCycle(target)
    if Config.VoidSpamRunning then return end
    Config.VoidSpamRunning = true

    local myChar = LP.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then Config.VoidSpamRunning=false return end

    local originalCF = myHRP.CFrame

    -- Phase 1: Hide underground in void
    local underVoid = CFrame.new(0, Config.VoidSpamVoidY, 0)
    myHRP.CFrame               = underVoid
    myHRP.AssemblyLinearVelocity = Vector3.zero
    task.wait(Config.VoidSpamHide)

    -- Phase 2: Snap to target + shoot
    local targetChr = target and target.Character
    local targetHRP = targetChr and targetChr:FindFirstChild("HumanoidRootPart")
    if targetHRP then
        -- Teleport just above target
        myHRP.CFrame = CFrame.new(targetHRP.Position + Vector3.new(0, 3, 0))
        myHRP.AssemblyLinearVelocity = Vector3.zero

        -- Fire shots
        for i = 1, Config.VoidSpamShots do
            pcall(function()
                local tool = myChar:FindFirstChildOfClass("Tool")
                if tool then
                    local remote = tool:FindFirstChild("RemoteEvent")
                    if remote then remote:FireServer() end
                    -- Also try ActivateServer pattern
                    local activate = tool:FindFirstChild("Activate")
                    if activate and activate:IsA("RemoteEvent") then activate:FireServer() end
                end
            end)
            if i < Config.VoidSpamShots then task.wait(0.05) end
        end

        task.wait(Config.VoidSpamAttack)
    end

    -- Phase 3: Return to underground void briefly
    myHRP.CFrame = underVoid
    myHRP.AssemblyLinearVelocity = Vector3.zero
    task.wait(0.08)

    -- Phase 4: Return to original position
    myHRP.CFrame = originalCF
    myHRP.AssemblyLinearVelocity = Vector3.zero

    Config.VoidSpamRunning = false
end

